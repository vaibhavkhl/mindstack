---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-zinc-950 text-zinc-50 antialiased selection:bg-zinc-800 selection:text-white">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — ThoughtBox</title>
  </head>
  <body class="min-h-screen flex flex-col justify-between font-sans">
    <slot />
  </body>
</html>