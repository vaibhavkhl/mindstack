---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Recall Memory">
  <main class="max-w-3xl mx-auto w-full pt-16 pb-12 px-6">
    
    <!-- Top Nav Backlink -->
    <header class="mb-12 flex justify-between items-center border-b border-zinc-900 pb-6">
      <div>
        <a href="/" class="text-xs font-mono text-zinc-500 hover:text-zinc-300 transition-colors">← Go back to Ingestion</a>
        <h1 class="text-xl font-bold tracking-tight mt-1">Semantic Memory Query</h1>
      </div>
    </header>

    <!-- Prominent Top-Center Search Input Component -->
    <section class="mb-10">
      <div class="relative max-w-2xl mx-auto">
        <input 
          type="text" 
          id="searchInput" 
          class="w-full pl-5 pr-14 py-4 rounded-xl bg-zinc-900/50 border border-zinc-800 text-zinc-100 placeholder-zinc-600 focus:outline-none focus:border-zinc-700 font-sans text-base shadow-lg transition-all duration-200"
          placeholder="Query your mindstack (e.g., 'database scaling constraints')..."
        />
        <button 
          id="searchBtn"
          class="absolute right-3 top-3 px-3 py-1.5 bg-zinc-800 text-zinc-300 border border-zinc-700 hover:bg-zinc-700 text-xs font-mono rounded-lg transition-all"
        >
          Query
        </button>
      </div>
      <p id="feedbackText" class="text-center text-xs font-mono text-zinc-600 mt-3 min-h-[16px]"></p>
    </section>

    <!-- Main Results Column Block -->
    <section class="space-y-8">
      
      <!-- 1. LLM Contextual Synthesis Output Area -->
      <div id="synthesisWrapper" class="hidden space-y-3">
        <h3 class="text-xs font-mono text-zinc-500 uppercase tracking-wider flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
          Groq AI Contextual Synthesis
        </h3>
        <div class="p-6 bg-zinc-900/20 border border-zinc-800/80 rounded-xl">
          <p id="synthesisContent" class="text-zinc-300 text-base leading-relaxed whitespace-pre-wrap font-sans"></p>
        </div>
      </div>

      <!-- 2. Raw Supporting Semantic Memories Grid -->
      <div id="memoriesWrapper" class="hidden space-y-4">
        <h3 class="text-xs font-mono text-zinc-500 uppercase tracking-wider">Retrieved Semantic Matches</h3>
        <div id="memoriesContainer" class="grid gap-4 sm:grid-cols-1">
          <!-- Raw vector record hits will inject here -->
        </div>
      </div>

    </section>

  </main>
</Layout>

<script>
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const searchBtn = document.getElementById('searchBtn') as HTMLButtonElement;
  const feedbackText = document.getElementById('feedbackText') as HTMLParagraphElement;
  const synthesisWrapper = document.getElementById('synthesisWrapper') as HTMLDivElement;
  const synthesisContent = document.getElementById('synthesisContent') as HTMLParagraphElement;
  const memoriesWrapper = document.getElementById('memoriesWrapper') as HTMLDivElement;
  const memoriesContainer = document.getElementById('memoriesContainer') as HTMLDivElement;

  async function executeSearch() {
    const queryStr = searchInput.value.trim();
    if (!queryStr) return;

    // Reset layout UI components to loading configurations
    searchBtn.disabled = true;
    searchBtn.textContent = "..."
    feedbackText.className = "text-center text-xs font-mono text-zinc-500 mt-3";
    feedbackText.textContent = "Embedding string & running vector matrix lookup...";
    synthesisWrapper.classList.add('hidden');
    memoriesWrapper.classList.add('hidden');

    try {
      const response = await fetch(`/api/search?q=${encodeURIComponent(queryStr)}`);
      const data = await response.json();

      if (!response.ok) throw new Error(data.error || 'Query aborted');

      feedbackText.textContent = "";

      // Render the AI Synthesis Markdown Content block
      synthesisContent.textContent = data.synthesis;
      synthesisWrapper.classList.remove('hidden');

      // Unpack raw matching records array
      memoriesContainer.innerHTML = '';
      if (data.relatedThoughts && data.relatedThoughts.length > 0) {
        data.relatedThoughts.forEach((thought: any) => {
          const card = document.createElement('div');
          card.className = "p-5 bg-zinc-900/40 border border-zinc-800/60 rounded-xl flex flex-col justify-between gap-4";
          
          // Render tags array safely
          const entityBadges = thought.entities.map((e: string) => 
            `<span class="text-[10px] px-2 py-0.5 bg-zinc-950 border border-zinc-800/80 rounded font-mono text-zinc-400">${e}</span>`
          ).join('');

          card.innerHTML = `
            <div class="space-y-2">
              <div class="flex justify-between items-start gap-4">
                <span class="text-xs font-mono text-indigo-400 font-medium">Score: ${(thought.score * 100).toFixed(1)}%</span>
                <span class="text-[10px] font-mono text-zinc-600">${new Date(thought.createdAt).toLocaleDateString()}</span>
              </div>
              <p class="text-sm text-zinc-300 leading-relaxed font-sans">${thought.text}</p>
            </div>
            <div class="flex flex-wrap gap-1.5 pt-2 border-t border-zinc-900">
              ${entityBadges || '<span class="text-[10px] text-zinc-600 font-mono italic">No metadata entities</span>'}
            </div>
          `;
          memoriesContainer.appendChild(card);
        });
        memoriesWrapper.classList.remove('hidden');
      } else {
        feedbackText.textContent = "Vector map completed successfully with zero matching contexts.";
      }

    } catch (err: any) {
      feedbackText.className = "text-center text-xs font-mono text-rose-500 mt-3";
      feedbackText.textContent = `Search Error: ${err.message}`;
    } finally {
      searchBtn.disabled = false;
      searchBtn.textContent = "Query";
    }
  }

  // Bind to submission interactions
  searchBtn?.addEventListener('click', executeSearch);
  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') executeSearch();
  });
</script>